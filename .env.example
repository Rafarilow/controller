# Banco de dados
POSTGRES_DB=controller
POSTGRES_USER=controller
POSTGRES_PASSWORD=TrocaPorUmaSenhaForte2024!

# JWT — gere uma chave aleatória (mín. 32 chars)
# Linux/Mac: openssl rand -base64 48
# Windows PowerShell: [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
JWT_KEY=Troque-isso-por-uma-chave-segura-de-pelo-menos-32-caracteres!

# IP ou domínio do servidor (sem http://)
SERVER_HOST=SEU_IP_AQUI
